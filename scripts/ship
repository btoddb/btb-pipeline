#!/usr/bin/env bash
#
# Ship this reusable workflow repo, then float the lightweight v1 tag so client
# repositories pinned at @v1 pick up the release.
#
set -euo pipefail

MAJOR_TAG="v1"
REMOTE="origin"
DRY_RUN=false

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
METADATA_FILE="$(mktemp)"
cleanup() {
    rm -f "$METADATA_FILE"
}
trap cleanup EXIT

for arg in "$@"; do
    case "$arg" in
        --dry-run) DRY_RUN=true ;;
    esac
done

"$SCRIPT_DIR/btb-ship-base" \
    --repo-root "$REPO_ROOT" \
    --require-major "$MAJOR_TAG" \
    --metadata-file "$METADATA_FILE" \
    "$@"

# shellcheck disable=SC1090
source "$METADATA_FILE"

release_sha="$(git -C "$REPO_ROOT" rev-parse HEAD)"
short_sha="$(git -C "$REPO_ROOT" rev-parse --short HEAD)"

if "$DRY_RUN"; then
    echo "DRY-RUN: git -C $REPO_ROOT tag -f $MAJOR_TAG $release_sha"
    echo "DRY-RUN: git -C $REPO_ROOT push -f $REMOTE $MAJOR_TAG"
else
    git -C "$REPO_ROOT" tag -f "$MAJOR_TAG" "$release_sha"
    git -C "$REPO_ROOT" push -f "$REMOTE" "$MAJOR_TAG"
fi

echo "Done. $MAJOR_TAG now points at $short_sha; consumers pinned @$MAJOR_TAG get it on their next run."
